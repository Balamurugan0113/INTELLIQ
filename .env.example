# Copy as .env and adjust for your cloud/platform

# Postgres (docker-compose uses these)
POSTGRES_USER=intelliq
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=intelliq
POSTGRES_PORT=5432
POSTGRES_HOST=db

# Backend SQLAlchemy URL (docker-compose service name "db")
DATABASE_URL=postgresql+psycopg2://intelliq:supersecret@db:5432/intelliq

# Frontend -> Backend URL
# For local dev:
VITE_API_URL=http://localhost:8000
# For cloud (example):
# VITE_API_URL=https://your-backend.example.com

# Admin token for protected endpoints
ADMIN_TOKEN=supersecretadmintoken